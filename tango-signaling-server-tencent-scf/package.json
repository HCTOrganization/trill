{
  "name": "tango-signaling-server-tencent-scf",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "proto": "mkdir -p src/proto && npx pbjs -t static-module -w es6 -o src/proto/signaling.js ../tango-signaling/src/proto/signaling.proto && npx pbts -o src/proto/signaling.d.ts src/proto/signaling.js",
    "build": "npm run proto && tsc",
    "typecheck": "tsc --noEmit",
    "dev": "npm run build && node dist/index.js",
    "deploy": "npm run build && serverless deploy"
  },
  "dependencies": {
    "express": "^4.18.2",
    "protobufjs": "^7.4.0",
    "ws": "^8.14.2",
    "redis": "^4.6.11"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/ws": "^8.5.10",
    "protobufjs-cli": "^1.1.3",
    "typescript": "^5.6.2",
    "serverless": "^3.38.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
