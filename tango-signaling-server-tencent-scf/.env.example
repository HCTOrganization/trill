# Tencent Cloud SCF Deployment Configuration
# Copy this file to .env.local and fill in your values

# Optional: Custom TURN server configuration
# If not set, the server will use Google's public STUN servers
TURN_ADDR=your-turn-server.com
TURN_USER=your-turn-username
TURN_CREDENTIAL=your-turn-credential

# Server configuration
NODE_ENV=development
PORT=3000

# Tencent Cloud SCF configuration (only used when deploying)
# These are typically set in serverless.yml or console
TENCENTCLOUD_SECRET_ID=your-secret-id
TENCENTCLOUD_SECRET_KEY=your-secret-key
TENCENTCLOUD_REGION=ap-shanghai
