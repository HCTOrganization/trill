# Tango Signaling Server Configuration

# Self-hosted TURN server (optional, takes priority over Cloudflare)
# TURN_ADDR=turn.example.com:3478
# TURN_USER=username
# TURN_CREDENTIAL=password

# Cloudflare TURN service (optional)
# CLOUDFLARE_TURN_SERVICE_ID=your-service-id
# CLOUDFLARE_TURN_SERVICE_API_TOKEN=your-api-token

# Server configuration
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
